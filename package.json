    "test:coverage": "jest --coverage"
  },
  "publishConfig": {
    "access": "public",
    "module": "dist/index.mjs",
    "main": "dist/index.js"
  },
  "dependencies": {
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-node-resolve": "^16.0.1",
