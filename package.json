{
  "name": "ws-emitter",
  "version": "0.1.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "repository": {
    "type": "git",
    "url": "https://github.com/arsenicum32/ws-emitter.git"
  },
  "bugs": {
    "url": "https://github.com/arsenicum32/ws-emitter/issues"
  },
  "homepage": "https://github.com/arsenicum32/ws-emitter#readme",
